{
  "name": "edge-core-chat-server",
  "version": "1.0.0",
  "description": "Backend server for Edge Core Chat with Azure AI Foundry",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "concurrently \"tsx watch index.ts\" \"npm run typecheck:watch\" \"chokidar '*.ts' -c 'npm run lint' --initial\"",
    "dev:no-lint": "tsx watch index.ts",
    "start": "tsx index.ts",
    "build": "echo 'No build step needed - tsx runs TypeScript directly'",
    "prebuild:check": "npm run lint && npm run typecheck",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "seed": "tsx scripts/seed-conversations.ts",
    "seed:batch": "tsx scripts/seed-conversations.ts batch",
    "seed:real": "tsx scripts/seed-conversations.ts real",
    "toggle": "./scripts/toggle.sh",
    "settings": "./scripts/show-settings.sh"
  },
  "dependencies": {
    "@azure/ai-projects": "^2.0.0-beta.4",
    "@azure/identity": "^4.6.0",
    "@azure/keyvault-secrets": "^4.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "morgan": "^1.10.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.18.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.21.0"
  }
}
